# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_CLIENT_ID: Required for Google Sign-In feature.
# Steps to obtain:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project → APIs & Services → Credentials
#   3. Create "OAuth 2.0 Client ID" (Web application type)
#   4. Add "http://localhost:3000" to "Authorized JavaScript origins"
#   5. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# =============================================================================
#  Supabase 雲端資料庫（資料持久化 + 真實認證）
#  取得方式：https://supabase.com → 建立專案 → Project Settings → API
# =============================================================================
# VITE_SUPABASE_URL: 你的 Supabase 專案 URL
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# VITE_SUPABASE_ANON_KEY: anon public 金鑰（前端用，受 RLS 保護）
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# --- 後端 core_bridge.py 推送事件用（伺服器端，請勿放前端）---
# SUPABASE_URL 與上面相同；SERVICE_ROLE 金鑰可繞過 RLS，僅供後端
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
# 此後端對應的裝置 ID（在 devices 表建立後填入）
WICARE_DEVICE_ID="YOUR_DEVICE_UUID"
